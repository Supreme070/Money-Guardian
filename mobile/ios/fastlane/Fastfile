default_platform(:ios)

platform :ios do
  desc "Sync certificates and profiles from Match"
  lane :sync_certs do
    match(type: "appstore", readonly: true)
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    sync_certs

    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || (latest_testflight_build_number + 1).to_s
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "../build/ios",
      export_options: {
        provisioningProfiles: {
          "com.moneyguardian.app" => "match AppStore com.moneyguardian.app"
        }
      }
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Build for App Store release"
  lane :release do
    sync_certs

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "../build/ios",
    )

    upload_to_app_store(
      force: true,
      skip_screenshots: false,
      skip_metadata: false,
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
    )
  end

  desc "Initialize Match certificates (run once)"
  lane :setup_certs do
    match(type: "development")
    match(type: "appstore")
  end
end
