# ────────────────────────────────────────────────────────────────────────────
# Money Guardian — Production Environment Variables
#
# Copy this file to .env and fill in all values marked REQUIRED.
# Generate secrets with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ────────────────────────────────────────────────────────────────────────────

# Application
APP_NAME=Money Guardian API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ──── Database (REQUIRED) ────
POSTGRES_USER=moneyguardian
POSTGRES_PASSWORD=           # REQUIRED: strong random password
POSTGRES_DB=money_guardian

# ──── Redis (REQUIRED) ────
REDIS_PASSWORD=              # REQUIRED: strong random password

# ──── JWT (REQUIRED) ────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=              # REQUIRED: 64+ character random string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ──── Encryption (REQUIRED) ────
# MUST be different from JWT_SECRET_KEY
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_MASTER_KEY=       # REQUIRED: separate from JWT secret

# ──── Admin API (REQUIRED) ────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=               # REQUIRED: for admin portal access

# ──── Stripe (REQUIRED for payments) ────
STRIPE_SECRET_KEY=           # sk_live_...
STRIPE_WEBHOOK_SECRET=       # whsec_...
STRIPE_PRO_PRICE_ID=         # price_...

# ──── Plaid (REQUIRED for bank connections) ────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENVIRONMENT=production
PLAID_WEBHOOK_URL=https://api.moneyguardian.app/api/v1/webhooks/plaid

# ──── Firebase (REQUIRED for push notifications) ────
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ──── Google OAuth (REQUIRED for Gmail scanning) ────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.moneyguardian.app/api/v1/email/oauth/callback

# ──── Microsoft OAuth (optional, for Outlook scanning) ────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://api.moneyguardian.app/api/v1/email/oauth/callback

# ──── Email (REQUIRED for verification & password reset) ────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                   # your-email@gmail.com
SMTP_PASSWORD=               # app-specific password
SMTP_FROM_EMAIL=noreply@moneyguardian.app
SMTP_FROM_NAME=Money Guardian

# ──── Sentry (recommended) ────
SENTRY_DSN=                  # https://xxx@sentry.io/yyy
SENTRY_TRACES_SAMPLE_RATE=0.1

# ──── CORS ────
CORS_ORIGINS=["https://app.moneyguardian.app","https://admin.moneyguardian.app"]

# ──── URLs ────
FRONTEND_URL=https://app.moneyguardian.app

# ──── Flower (Celery monitoring) ────
FLOWER_USER=admin
FLOWER_PASSWORD=             # REQUIRED if using Flower

# ──── Nginx Ports ────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
